# Copie ce fichier en ".env" et renseigne ta cle.

# Cle API Google AI Studio : https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Modele Gemini (vision + PDF). Un modele "flash-lite" = le plus petit/economique.
GEMINI_MODEL=gemini-3.1-flash-lite

# Dossier a surveiller. Si vide -> sous-dossier "scans" a cote du programme.
WATCH_DIR=

# DRY_RUN=true : analyse et affiche le nom propose SANS renommer (pour tester).
DRY_RUN=false

# SCAN_EXISTING=true : traite aussi les fichiers deja presents au demarrage.
SCAN_EXISTING=false
